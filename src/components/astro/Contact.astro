---
import FadeUp from '../react/FadeUp.tsx';
import { CONTACT, SERVICE_AREAS, waLink } from '../../lib/content';
---

<section id="contacto" class="bg-sand-50 py-section">
  <div class="mx-auto max-w-7xl px-6 md:px-12">
    <FadeUp client:visible>
      <p class="text-xs uppercase tracking-[0.25em] text-ink-mute">
        Hablemos
      </p>

      <h2 class="mt-6 max-w-4xl text-display-lg">
        ¿Tenés una idea, una duda
        <span class="font-display italic font-light text-ink-soft">
          o un proyecto mirándote desde hace meses?
        </span>
      </h2>
    </FadeUp>

    <div class="mt-16 grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-16">
      <FadeUp client:visible delay={0.1} className="md:col-span-7">
        <div class="space-y-6">
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between border-t border-sand-300/60 py-6 text-ink transition-colors hover:text-ink-soft"
          >
            <span class="flex items-baseline gap-4">
              <span class="text-xs uppercase tracking-[0.2em] text-ink-mute">
                01
              </span>
              <span class="text-2xl md:text-3xl">WhatsApp</span>
            </span>
            <span
              aria-hidden
              class="text-2xl transition-transform duration-500 group-hover:translate-x-1"
            >
              →
            </span>
          </a>

          <a
            href={`mailto:${CONTACT.email}`}
            class="group flex items-center justify-between border-t border-sand-300/60 py-6 text-ink transition-colors hover:text-ink-soft"
          >
            <span class="flex items-baseline gap-4">
              <span class="text-xs uppercase tracking-[0.2em] text-ink-mute">
                02
              </span>
              <span class="text-2xl md:text-3xl">{CONTACT.email}</span>
            </span>
            <span
              aria-hidden
              class="text-2xl transition-transform duration-500 group-hover:translate-x-1"
            >
              →
            </span>
          </a>
        </div>
      </FadeUp>

      <FadeUp client:visible delay={0.2} className="md:col-span-5">
        <div class="border border-sand-300/60 p-8 md:p-10">
          <p class="text-xs uppercase tracking-[0.25em] text-ink-mute">
            Dónde trabajo
          </p>
          <p class="mt-6 font-display text-2xl leading-snug text-ink md:text-3xl">
            {SERVICE_AREAS.join(' · ')}
          </p>
          <p class="mt-6 text-sm leading-relaxed text-ink-soft">
            ¿Vivís fuera de estas zonas? Escribime igual — algunos
            proyectos los acompaño a distancia.
          </p>
        </div>
      </FadeUp>
    </div>
  </div>
</section>
