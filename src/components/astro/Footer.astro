---
import { CONTACT, SITE } from '../../lib/content';
const year = new Date().getFullYear();
---

<footer class="border-t border-sand-300/60 bg-sand-100">
  <div class="mx-auto max-w-7xl px-6 py-16 md:px-12 md:py-20">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <p class="font-display text-2xl text-ink">{SITE.name}</p>
        <p class="mt-2 text-sm text-ink-soft">
          {SITE.role} · Estudio independiente
        </p>
      </div>

      <nav class="md:col-span-3" aria-label="Navegación">
        <p class="text-xs uppercase tracking-[0.25em] text-ink-mute">
          Navegar
        </p>
        <ul class="mt-4 space-y-2 text-sm text-ink-soft">
          <li><a href="#sobre-mi" class="transition-colors hover:text-ink">Sobre mí</a></li>
          <li><a href="#servicios" class="transition-colors hover:text-ink">Servicios</a></li>
          <li><a href="#trabajos" class="transition-colors hover:text-ink">Trabajos</a></li>
          <li><a href="#contacto" class="transition-colors hover:text-ink">Contacto</a></li>
        </ul>
      </nav>

      <div class="md:col-span-4">
        <p class="text-xs uppercase tracking-[0.25em] text-ink-mute">
          Redes
        </p>
        <ul class="mt-4 space-y-2 text-sm text-ink-soft">
          <li>
            <a
              href={CONTACT.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-ink"
            >
              Instagram ↗
            </a>
          </li>
          <li>
            <a
              href={CONTACT.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-ink"
            >
              LinkedIn ↗
            </a>
          </li>
          <li>
            <a
              href={`mailto:${CONTACT.email}`}
              class="transition-colors hover:text-ink"
            >
              {CONTACT.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-start justify-between gap-2 border-t border-sand-300/60 pt-8 text-xs text-ink-mute md:flex-row md:items-center">
      <p>© {year} {SITE.name}. Todos los derechos reservados.</p>
      <p>
        Diseño y desarrollo por
        <span class="text-ink-soft">Bruno Garibaldi</span>
      </p>
    </div>
  </div>
</footer>
