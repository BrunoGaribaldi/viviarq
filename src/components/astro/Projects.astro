---
import FadeUp from '../react/FadeUp.tsx';
import { PROJECTS } from '../../lib/content';

const spanClass: Record<string, string> = {
  wide: 'md:col-span-7',
  narrow: 'md:col-span-5',
  half: 'md:col-span-6',
};

const aspectClass: Record<string, string> = {
  landscape: 'aspect-[4/3]',
  portrait: 'aspect-[4/5]',
};
---

<section id="trabajos" class="bg-sand-50 py-section">
  <div class="mx-auto max-w-7xl px-6 md:px-12">
    <div class="flex flex-col items-start gap-6 md:flex-row md:items-end md:justify-between">
      <FadeUp client:visible>
        <p class="text-xs uppercase tracking-[0.25em] text-ink-mute">
          Trabajos
        </p>
        <h2 class="mt-6 max-w-3xl text-display-lg">
          Una selección de
          <span class="font-display italic font-light text-ink-soft">
            obras y procesos.
          </span>
        </h2>
      </FadeUp>

      <FadeUp client:visible delay={0.15} className="md:max-w-sm">
        <p class="text-sm leading-relaxed text-ink-soft md:text-right">
          Cada proyecto empieza con una conversación honesta sobre lo que de verdad hace falta. Estos son algunos de los que
          terminamos juntos.
        </p>
      </FadeUp>
    </div>

    <ul class="mt-16 grid grid-cols-1 gap-x-6 gap-y-12 md:mt-24 md:grid-cols-12 md:gap-x-8 md:gap-y-20">
      {
        PROJECTS.map((p, idx) => (
          <FadeUp
            client:visible
            delay={(idx % 2) * 0.12}
            as="div"
            className={spanClass[p.span] ?? 'md:col-span-6'}
          >
            <li class="group">
              <a
                href={`#${p.id}`}
                class="block focus:outline-none"
                aria-label={`Ver proyecto ${p.title}`}
              >
                <div
                  class={`relative overflow-hidden bg-sand-200 ${aspectClass[p.aspect] ?? 'aspect-[4/3]'}`}
                >
                  <img
                    src={p.image}
                    alt={p.alt}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-[1200ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.04]"
                  />
                  <div class="pointer-events-none absolute inset-0 bg-ink/0 transition-colors duration-700 group-hover:bg-ink/10" />
                </div>

                <div class="mt-5 flex items-baseline justify-between gap-4">
                  <div>
                    <h3 class="font-display text-xl text-ink md:text-2xl">
                      {p.title}
                    </h3>
                    <p class="mt-1 text-sm text-ink-soft">
                      {p.location} · {p.type}
                    </p>
                  </div>
                  <span class="shrink-0 text-xs uppercase tracking-[0.2em] text-ink-mute">
                    {p.year}
                  </span>
                </div>
              </a>
            </li>
          </FadeUp>
        ))
      }
    </ul>
  </div>
</section>
