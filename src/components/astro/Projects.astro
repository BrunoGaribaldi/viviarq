---
import FadeUp from '../react/FadeUp.tsx';
import { PROJECTS } from '../../lib/content';

const colSpanClass: Record<number, string> = {
  4: 'md:col-span-4',
  5: 'md:col-span-5',
  6: 'md:col-span-6',
  7: 'md:col-span-7',
  8: 'md:col-span-8',
};
---

<section id="trabajos" class="bg-sand-100 py-section">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 md:px-12">
    <div class="flex flex-col items-start gap-6 md:flex-row md:items-end md:justify-between">
      <FadeUp client:visible>
        <p class="text-xs uppercase tracking-[0.25em] text-ink-mute">
          Trabajos
        </p>
        <h2 class="mt-6 max-w-3xl text-display-lg">
          Una selección de
          <span class="font-display italic font-light text-ink-soft">
            obras y procesos.
          </span>
        </h2>
      </FadeUp>

      <FadeUp client:visible delay={0.15} className="md:max-w-sm">
        <p class="text-sm leading-relaxed text-ink-soft md:text-right">
          Cada proyecto empieza con una conversación honesta sobre lo que de
          verdad hace falta. Estos son algunos de los que terminamos juntos en
          Villa Carlos Paz y Córdoba.
        </p>
      </FadeUp>
    </div>

    <ul class="mt-16 grid grid-cols-1 gap-x-6 gap-y-12 md:mt-24 md:grid-cols-12 md:gap-x-8 md:gap-y-20">
      {
        PROJECTS.map((p, idx) => (
          <FadeUp
            client:visible
            delay={(idx % 2) * 0.12}
            as="div"
            className={colSpanClass[p.colSpan] ?? 'md:col-span-6'}
          >
            <li class="group">
              <div class={`relative overflow-hidden bg-sand-200 ${p.aspect}`}>
                {p.kind === 'video' ? (
                  <>
                    <video
                      src={p.src}
                      width={p.width}
                      height={p.height}
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      aria-label={p.alt}
                      class="h-full w-full object-cover transition-transform duration-[1200ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.04]"
                      style="filter: contrast(1.05) saturate(0.92);"
                    />
                    <div class="pointer-events-none absolute inset-0 bg-sand-50/10 mix-blend-multiply" />
                  </>
                ) : p.kind === 'collage' ? (
                  <>
                    <img
                      src={p.src}
                      alt={p.alt}
                      width={p.width}
                      height={p.height}
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-cover object-center transition-transform duration-[1200ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.02]"
                    />
                    <div
                      class="absolute bottom-4 right-4 w-[42%] max-w-[260px] overflow-hidden border-4 border-sand-50 bg-sand-50 shadow-[0_18px_40px_-12px_rgba(43,36,29,0.45)] transition-transform duration-[1200ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.03] sm:bottom-6 sm:right-6 sm:w-[36%] md:w-[34%] md:border-[6px]"
                    >
                      <img
                        src={p.overlaySrc}
                        alt={p.overlayAlt}
                        loading="lazy"
                        decoding="async"
                        class="block aspect-[4/3] h-auto w-full object-cover"
                      />
                    </div>
                  </>
                ) : (
                  <img
                    src={p.src}
                    alt={p.alt}
                    width={p.width}
                    height={p.height}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover object-center transition-transform duration-[1200ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.04]"
                  />
                )}
                <div class="pointer-events-none absolute inset-0 bg-ink/0 transition-colors duration-700 group-hover:bg-ink/10" />
              </div>

              <div class="mt-5 flex items-baseline justify-between gap-4">
                <div class="min-w-0">
                  <h3 class="font-display text-xl text-ink md:text-2xl">
                    {p.title}
                  </h3>
                  <p class="mt-1 truncate text-sm text-ink-soft">
                    {p.location} · {p.type}
                  </p>
                </div>
                <span class="shrink-0 text-xs uppercase tracking-[0.2em] text-ink-mute">
                  {p.year}
                </span>
              </div>
            </li>
          </FadeUp>
        ))
      }
    </ul>
  </div>
</section>
