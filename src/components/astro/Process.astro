---
import FadeUp from '../react/FadeUp.tsx';
import { DETAIL_RENDER, DETAIL_OBRA } from '../../lib/content';
---

<section class="bg-sand-50 py-section">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 md:px-12">
    <div class="flex flex-col items-start gap-6 md:flex-row md:items-end md:justify-between">
      <FadeUp client:visible>
        <p class="text-xs uppercase tracking-[0.25em] text-ink-mute">
          Proceso
        </p>
        <h2 class="mt-6 max-w-3xl text-display-md">
          Del render
          <span class="font-display italic font-light text-ink-soft">
            a la obra.
          </span>
        </h2>
      </FadeUp>

      <FadeUp client:visible delay={0.15} className="md:max-w-sm">
        <p class="text-sm leading-relaxed text-ink-soft md:text-right">
          Cada proyecto recorre el mismo camino: pensarlo, dibujarlo y
          después estar en la obra para que termine siendo lo que
          imaginamos.
        </p>
      </FadeUp>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 md:mt-16 md:grid-cols-12 md:gap-8">
      <FadeUp client:visible delay={0.1} as="div" className="md:col-span-8">
        <figure class="group">
          <div class="relative aspect-video overflow-hidden bg-sand-200">
            <img
              src={DETAIL_RENDER.src}
              alt={DETAIL_RENDER.alt}
              width={DETAIL_RENDER.width}
              height={DETAIL_RENDER.height}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-[1200ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.03]"
            />
            <div class="pointer-events-none absolute inset-0 bg-ink/0 transition-colors duration-700 group-hover:bg-ink/10" />
          </div>
          <figcaption class="mt-4 flex items-baseline justify-between gap-4 text-xs uppercase tracking-[0.2em] text-ink-mute">
            <span>Render · Proyecto en desarrollo</span>
            <span>2025</span>
          </figcaption>
        </figure>
      </FadeUp>

      <FadeUp client:visible delay={0.2} as="div" className="md:col-span-4">
        <figure class="group">
          <div class="relative aspect-[2/3] overflow-hidden bg-sand-200">
            <img
              src={DETAIL_OBRA.src}
              alt={DETAIL_OBRA.alt}
              width={DETAIL_OBRA.width}
              height={DETAIL_OBRA.height}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-[1200ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.03]"
            />
            <div class="pointer-events-none absolute inset-0 bg-ink/0 transition-colors duration-700 group-hover:bg-ink/10" />
          </div>
          <figcaption class="mt-4 flex items-baseline justify-between gap-4 text-xs uppercase tracking-[0.2em] text-ink-mute">
            <span>Dirección de obra</span>
            <span>2025</span>
          </figcaption>
        </figure>
      </FadeUp>
    </div>
  </div>
</section>
